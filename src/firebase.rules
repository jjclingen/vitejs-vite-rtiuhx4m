rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAllowed() {
      return request.auth != null &&
        request.auth.token.email in
        get(/databases/$(database)/documents/households/main).data.allowedEmails;
    }
    function isSetup() {
      return !exists(/databases/$(database)/documents/households/main);
    }
    match /households/main {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (isSetup() ||
         request.auth.token.email == resource.data.adminEmail ||
         request.auth.token.email in resource.data.allowedEmails);
    }
    match /{collection}/{document} {
      allow read, write: if isAllowed();
    }
  }
}
